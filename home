      <input type="color" value="#fc5229" oninput="setAccent(this.value)">
    </div>
    <div class="lj-editor-row">
      <div class="lj-editor-lbl">Hero title dòng highlight</div>
      <input type="text" value="đi một mình." oninput="document.querySelector('h1 em').textContent=this.value">
    </div>
    <div class="lj-editor-row">
      <div class="lj-editor-lbl">Hero subtitle</div>
      <input type="text" value="Kết nối với advisor đang làm thật..." oninput="document.querySelector('.lj-hero-sub').textContent=this.value">
