    <div class="lj-editor-row">
      <div class="lj-editor-lbl">Stat: kết nối đã diễn ra</div>
      <input type="text" value="200+" oninput="document.querySelectorAll('.lj-stat-num')[0].textContent=this.value">
    </div>
    <div class="lj-editor-row">
      <div class="lj-editor-lbl">Stat: số advisors</div>
      <input type="text" value="25+" oninput="document.querySelectorAll('.lj-stat-num')[1].textContent=this.value">
    </div>
  </div>
</div>

<script>
function toggleEd(){
  var b=document.getElementById('edbody'),btn=document.getElementById('edbtn');
  b.classList.toggle('collapsed');
  btn.textContent=b.classList.contains('collapsed')?'▸':'▾';
}
function setAccent(c){
  var r=parseInt(c.slice(1,3),16),g=parseInt(c.slice(3,5),16),b=parseInt(c.slice(5,7),16);
  var rgb=`rgba(${r},${g},${b},`;
  document.querySelectorAll('.lj-logo').forEach(e=>e.style.color=c);
  document.querySelectorAll('.lj-btn-nav,.lj-btn-primary').forEach(e=>e.style.background=c);
  document.querySelectorAll('.lj-cta-box').forEach(e=>e.style.background=c);
  document.querySelectorAll('.lj-stat-num').forEach(e=>e.style.color=c);
  document.querySelectorAll('.lj-pill-dot').forEach(e=>e.style.background=c);
  document.querySelectorAll('.lj-ticker-item span').forEach(e=>e.style.color=c);
  document.querySelectorAll('.lj-offer-badge').forEach(e=>{e.style.color=c;e.style.background=rgb+'0.1)';});
  document.querySelectorAll('.lj-svc-badge').forEach(e=>{e.style.color=c;e.style.background=rgb+'0.1)';e.style.borderColor=rgb+'0.2)';});
  document.querySelectorAll('.lj-about-icon-wrap').forEach(e=>e.style.background=rgb+'0.1)');
  document.querySelectorAll('.lj-about-icon-wrap i').forEach(e=>e.style.color=c);
  document.querySelectorAll('.lj-benefit-icon').forEach(e=>e.style.background=rgb+'0.08)');
  document.querySelectorAll('.lj-benefit-icon i').forEach(e=>e.style.color=c);
  document.querySelectorAll('.lj-btn-svc').forEach(e=>{e.style.color=c;e.style.background=rgb+'0.1)';e.style.borderColor=rgb+'0.25)';});
  document.querySelectorAll('.lj-btn-cta,.lj-btn-dark').forEach(e=>e.style.color=c);
  document.querySelectorAll('h1 em').forEach(e=>e.style.color=c);
  document.querySelectorAll('.lj-testi-ava').forEach(e=>e.style.color=c);
  document.querySelectorAll('.lj-editor-title').forEach(e=>e.style.color=c);
  document.querySelectorAll('.lj-ratio-bar:last-of-type').forEach(e=>e.style.background=c);
}
</script>
